# ==============================
# 环境变量模板 - 请勿直接提交真实密钥
# 使用方法: 复制为 .env 并填入真实值
# ==============================

# MySQL root 密码（仅 MySQL 容器使用）
MYSQL_ROOT_PASSWORD=change-me-root-123

# 数据库连接配置
DB_NAME=analytics_db
DB_USERNAME=analytics_user
DB_PASSWORD=change-me-user-456

# JWT 签名密钥（生产环境必须为 256-bit 以上随机字符串）
JWT_SECRET=change-me-jwt-secret-key-long-enough-256bit-minimum

# 慢查询阈值（毫秒）
SLOW_QUERY_THRESHOLD=500

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# JPA DDL 策略（生产环境建议 validate）
JPA_DDL_AUTO=validate

# 服务端口
SERVER_PORT=8080
